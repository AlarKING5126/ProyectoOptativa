# ============================================================
#  DEPORTES NEON — Variables de entorno
#  Copia este archivo como .env y completa tus datos
# ============================================================

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=deportes_neon
DB_USER=postgres
DB_PASSWORD=tu_password_aqui

# JWT (cambia por una cadena larga y aleatoria)
JWT_SECRET=deportes_neon_super_secret_key_2026_cambia_esto
JWT_EXPIRES_IN=7d

# Servidor
PORT=3000
NODE_ENV=development

# CORS — orígenes permitidos (separados por coma)
CORS_ORIGINS=http://localhost:5500,http://127.0.0.1:5500,http://localhost:3000
