# ============================================================
#  DEPORTES NEON — Variables de entorno
#  Copia este archivo como .env y completa tus datos
# ============================================================

# MySQL
DB_HOST=localhost
DB_PORT=3306
DB_NAME=deportes_neon
DB_USER=root
DB_PASSWORD=tu_password_aqui

# JWT — genera una cadena aleatoria segura:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=cambia_esto_por_una_cadena_aleatoria_larga
JWT_EXPIRES_IN=7d

# Servidor
PORT=3000
NODE_ENV=development

# CORS — orígenes permitidos (separados por coma)
CORS_ORIGINS=http://localhost:5500,http://127.0.0.1:5500,http://localhost:3000
